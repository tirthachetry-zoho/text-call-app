# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Service role key is server-only and must NEVER be exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# JWT secret used to sign Supabase-compatible sessions after phone-number
# registration. Found in Supabase Dashboard → Project Settings → API → JWT Settings.
SUPABASE_JWT_SECRET=your-jwt-secret

# ---------------------------------------------------------------------------
# Public site URL (used for redirects / callbacks)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Connection request rejection cooldown (in hours)
# ---------------------------------------------------------------------------
REJECTION_COOLDOWN_HOURS=24

# ---------------------------------------------------------------------------
# Rate limiting (requests per window)
# ---------------------------------------------------------------------------
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=60000